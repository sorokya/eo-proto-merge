<?xml version="1.0" encoding="UTF-8"?>
<protocol>
    <enum name="PacketFamily" type="byte">
        <value name="Connection">1</value>
        <value name="Walk">6</value>
        <value name="Talk">18</value>
    </enum>

    <enum name="Direction" type="char">
        <value name="Down">0</value>
        <value name="Left">1</value>
        <value name="Up">2</value>
        <value name="Right">3</value>
    </enum>

    <struct name="Coords">
        <field name="x" type="char"/>
        <field name="y" type="char"/>
    </struct>

    <enum name="ShapeType" type="char">
        <value name="Circle">1</value>
        <value name="Square">2</value>
    </enum>

    <!-- switch is a direct child -->
    <struct name="Shape">
        <field name="type" type="ShapeType"/>
        <switch field="type">
            <case value="Circle">
                <field name="radius" type="char"/>
            </case>
            <case value="Square">
                <field name="side" type="char"/>
            </case>
        </switch>
    </struct>

    <!-- switch is nested inside a chunked block -->
    <struct name="ShapeMessage">
        <chunked>
            <field name="type" type="ShapeType"/>
            <break/>
            <switch field="type">
                <case value="Circle">
                    <field name="data" type="string"/>
                </case>
            </switch>
        </chunked>
    </struct>

    <packet family="Walk" action="Player">
        <chunked>
            <field name="direction" type="Direction"/>
            <field name="timestamp" type="three"/>
            <field name="coords" type="Coords"/>
            <break/>
            <switch field="direction">
                <case value="Down">
                    <field name="speed" type="char"/>
                </case>
            </switch>
        </chunked>
    </packet>
</protocol>
