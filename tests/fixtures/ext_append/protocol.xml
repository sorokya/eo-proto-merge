<?xml version="1.0" encoding="UTF-8"?>
<!-- Append: add a new value to PacketFamily and a new field to WalkPlayer -->
<protocol>
    <enum name="PacketFamily" extend="append">
        <value name="Custom">100</value>
    </enum>

    <packet family="Walk" action="Player" extend="append">
        <field name="custom_data" type="string" />
    </packet>
</protocol>